# Photo Manager v2 配置文件模板
# 复制此文件为 .env 并填入实际值（.env 不会被提交到 git）

# Supabase
SUPABASE_URL=https://photo.qixingovo.cn
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_STORAGE_URL=https://photo.qixingovo.cn/storage/v1/object/public/photo/

# 安全
PEPPER=your-random-pepper-string

# 用户邮箱
USER_EMAILS_LAODA=laoda@couple.local
USER_EMAILS_XIAODI=xiaodi@couple.local

# 调试（可选）
DEBUG=false
