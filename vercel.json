{
  "version": 2,
  "buildCommand": "node scripts/build-config.js",
  "outputDirectory": ".",
  "installCommand": null,
  "framework": null,
  "rewrites": [
    { "source": "/auth/v1/:path*", "destination": "http://47.114.121.178.nip.io/auth/v1/:path*" },
    { "source": "/rest/v1/:path*", "destination": "http://47.114.121.178.nip.io/rest/v1/:path*" },
    { "source": "/storage/v1/:path*", "destination": "http://47.114.121.178.nip.io/storage/v1/:path*" }
  ],
  "headers": [
    {
      "source": "/:path*{.js,.css}",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*{.html,.json,.xml}",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/:path*",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
